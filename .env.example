# Docker Compose 开发环境配置模板
# 复制此文件为 .env 并根据需要修改

# ===========================================
# PostgreSQL 数据库配置
# ===========================================
POSTGRES_VERSION=15
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ttrss
POSTGRES_PORT=5432

# ===========================================
# 后端 Spring Boot 配置
# ===========================================
BACKEND_PORT=8080
BACKEND_IMAGE_NAME=ttrss-backend

# 数据库连接 (Docker 网络内部使用)
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/ttrss
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# ===========================================
# 前端 Vite 开发服务器配置
# ===========================================
FRONTEND_PORT=3000
FRONTEND_IMAGE_NAME=ttrss-frontend
VITE_API_BASE_URL=http://localhost:8080

# ===========================================
# HTTP 端口 (Web 访问)
# ===========================================
HTTP_PORT=8280
