# Normalize line endings to LF for all text files
* text=auto

# Explicitly set line endings for common file types
*.css text eol=lf
*.js text eol=lf
*.php text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf eol=lf
*.sql text eol=lf
*.xml text eol=lf
*.html text eol=lf
*.htm text eol=lf
*.less text eol=lf

# Exclude binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.zip binary
*.gz binary
*.tar binary